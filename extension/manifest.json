{
  "manifest_version": 3,
  "name": "HumbleTrust — Token TrustScore",
  "version": "1.0.0",
  "description": "See trust and safety scores for Solana tokens while browsing Solana DeFi — no tab switching needed.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://humbletrust.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dexscreener.com/*",
        "https://birdeye.so/*",
        "https://jup.ag/*",
        "https://solscan.io/*",
        "https://explorer.solana.com/*",
        "https://raydium.io/*",
        "https://orca.so/*",
        "https://pump.fun/*",
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HumbleTrust TrustScore",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
